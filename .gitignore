# --- WASMnism: AI Prompt Firewall — Edge Moderation Benchmark ---
# Security-first: never commit secrets, credentials, or environment-specific data.

.DS_Store

# --- Secrets / Credentials (NEVER commit) ---
.env
.env.*
!.env.example
**/*secret*
**/*password*
**/*credential*
**/*.pem
**/*.key
*.kubeconfig
**/*.kubeconfig
.kube/

# --- Cost config (use cost-config.example.yaml as template) ---
/cost/cost-config.yaml

# --- Cost model (contains competitive benchmark data) ---
/cost/cost-model.md

# --- Benchmark scripts with environment-specific URLs/IPs ---
/bench/run_config.yaml

# --- Benchmark results (may contain IPs, account IDs, internal URLs) ---
/results/
*.bench.json

# --- Terraform ---
.terraform/
.terraform.lock.hcl.backup
terraform.tfstate
terraform.tfstate.*
terraform.tfvars
crash.log
crash.*.log

# --- Project context (private - do not commit) ---
/docs/*.local.md

# --- Internal planning docs (local only) ---
/docs/CLIPCLAP_INSPECTION.md
/docs/EXECUTION_PLAN.md
/docs/INTERNAL_MEMO.md
/docs/OPUS_WORK_SUMMARY.md

# --- Blog export (local only) ---
/wasmnism-blog.*
/*-blog.*

# --- Planning docs (local only) ---
*.docx
~$*

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
venv/
.venv/

# --- PyTorch / ML model caches ---
*.pt
*.pth
*.ckpt
.cache/

# --- Node.js ---
node_modules/
npm-debug.log*

# --- Rust / WASM build ---
**/target/
*.wasm
!**/fixtures/*.wasm

# --- Vite / Build output ---
**/dist/
*.local

# --- IDE / Editor ---
.idea/
.vscode/
*.swp
*.swo
*~

# --- Logs ---
*.log
logs/

# --- Testing ---
.coverage
htmlcov/
.pytest_cache/

# --- Spin build artifacts (generated from frontend/) ---
edge-gateway/adapters/spin/static/
edge-gateway/adapters/spin/.spin/
edge-gateway/adapters/spin/.spin-aka/

# --- Fastly build artifacts ---
edge-gateway/adapters/fastly/pkg/
edge-gateway/adapters/fastly/bin/
edge-gateway/adapters/fastly/static/

# --- Lambda build artifacts ---
edge-gateway/adapters/lambda/static/
edge-gateway/adapters/lambda/models/

# --- Workers build artifacts ---
edge-gateway/adapters/workers/static/
edge-gateway/adapters/workers/.wrangler/

# --- ML model files (large binaries, downloaded/converted locally) ---
edge-gateway/models/toxicity/*.onnx
edge-gateway/models/toxicity/*.nnef.tar
edge-gateway/models/toxicity/vocab.txt
edge-gateway/models/toxicity/config.json

# --- Native baseline adapter (private, not part of public WASM comparison) ---
edge-gateway/adapters/native/

# --- Archive (legacy material, will be deleted) ---
_archive/

# --- Spin binary (install via curl, not committed) ---
/spin
/spin.sig

# k6 runner IPs (sensitive)
deploy/runners.env
