# --- WASMnism: ClipClap Edge Gateway Benchmark ---
# Security-first: never commit secrets, credentials, or environment-specific data.

.DS_Store

# --- Secrets / Credentials (NEVER commit) ---
.env
.env.*
!.env.example
**/*token*
**/*secret*
**/*password*
**/*credential*
**/*.pem
**/*.key
*.kubeconfig
**/*.kubeconfig
.kube/

# --- Cost config (use cost-config.example.yaml as template) ---
/cost/cost-config.yaml

# --- Benchmark scripts with environment-specific URLs/IPs ---
/scripts/run_all_benchmarks.sh
/bench/run_config.yaml
!.example

# --- Benchmark results (may contain IPs, account IDs, internal URLs) ---
/benchmarks/
/results/
*.bench.json

# --- Terraform ---
.terraform/
.terraform.lock.hcl.backup
terraform.tfstate
terraform.tfstate.*
terraform.tfvars
crash.log
crash.*.log

# --- Project context (private - do not commit) ---
/docs/PROJECT_STATE.local.md
/docs/PROJECT_STATE.public.md
/docs/OPERATIONS.local.md
/docs/OPERATIONS.public.md
/docs/CONTEXT.local.md
/docs/ENDPOINTS.local.md
/docs/*.local.md

# --- Internal planning docs (local only) ---
/docs/CLIPCLAP_INSPECTION.md
/docs/EXECUTION_PLAN.md
/docs/INTERNAL_MEMO.md
/docs/OPUS_WORK_SUMMARY.md

# --- Blog export (local only) ---
/wasmnism-blog.*
/*-blog.*

# --- Planning docs (local only) ---
*.docx
~$*

# --- Python (clipclap backend + inference-service) ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
*.egg-info/
.installed.cfg
*.egg
venv/
.venv/
env/
ENV/

# --- PyTorch / ML model caches ---
*.pt
*.pth
*.ckpt
.cache/
~/.cache/clip/
~/.cache/huggingface/
~/.cache/torch/

# --- Node.js ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Rust / WASM build ---
/target/
**/target/
*.wasm
!**/fixtures/*.wasm

# --- Vite / Build output ---
**/frontend/dist/
**/dist/
*.local

# --- IDE / Editor ---
.idea/
.vscode/
*.swp
*.swo
*~

# --- Logs ---
*.log
logs/

# --- Testing ---
.coverage
htmlcov/
.pytest_cache/
.tox/

# --- Clipclap sample data (downloaded on setup) ---
clipclap/backend/samples/images/
clipclap/backend/samples/audio/
