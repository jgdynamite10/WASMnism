# WASMnism environment configuration
# Copy to .env and fill in real values. NEVER commit .env.

# Inference service base URL (no trailing slash)
INFERENCE_URL=https://your-inference-service.example.com

# Gateway deployment region
GATEWAY_REGION=us-east-1

# --- Platform-specific credentials (set only what you need) ---

# Spin / Akamai
# SPIN_VARIABLE_INFERENCE_URL=https://your-inference-service.example.com
# SPIN_VARIABLE_GATEWAY_REGION=us-east-1

# Fastly
# FASTLY_API_TOKEN=your-fastly-token

# Cloudflare
# CLOUDFLARE_API_TOKEN=your-cloudflare-token
# CLOUDFLARE_ACCOUNT_ID=your-account-id

# AWS Lambda
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_DEFAULT_REGION=us-east-1
